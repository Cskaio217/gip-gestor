# =============================================================================
# GIP — Variáveis de Ambiente — Frontend (GitHub Pages)
# Copie este arquivo para .env.local e preencha com os valores do Supabase.
# O arquivo .env.local está no .gitignore e NUNCA será commitado.
# =============================================================================

# URL do projeto Supabase
# Encontrar em: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Chave pública (anon) — SEGURA para usar no frontend
# Encontrar em: Supabase Dashboard → Settings → API → anon public
# NUNCA use a service_role key aqui!
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
